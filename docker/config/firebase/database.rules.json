{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      ".read": false,
      ".write": false,
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null && data.exists() && !newData.exists() && data.hasChildren(['created_by','created_at']) && data.child('created_by').val() == auth.uid",
        ".validate": "!newData.exists() || (newData.hasChildren(['created_by','created_at']) && newData.child('created_by').isString() && newData.child('created_at').isNumber())"
      }
    },
    "$uid": {
      ".read": false,
      ".write": "auth != null && auth.uid == $uid && data.exists() && !newData.exists()",
      "$roomId": {
        ".read": false,
        ".write": "auth != null && auth.uid == $uid && !data.exists() && newData.exists() && newData.hasChildren(['created_at'])",
        ".validate": "!newData.exists() || (newData.hasChildren(['created_at']) && newData.child('created_at').isNumber())"
      }
    }
  }
}
