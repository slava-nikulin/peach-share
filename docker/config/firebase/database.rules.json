{
  "rules": {
    ".read": false,
    ".write": false,
    "$uid": {
      ".read": "auth != null && auth.uid === $uid",
      ".write": false,
      "$action": {
        ".read": false,
        ".write": "auth != null && auth.uid === $uid && ($action === 'create' || $action === 'join') && ((!data.exists() && newData.exists()) || (data.exists() && newData.exists() && data.child('created_at').isNumber() && data.child('created_at').val() <= now - 10000) || (data.exists() && !newData.exists() && data.child('created_at').isNumber() && data.child('created_at').val() <= now - 10000))",
        ".validate": "!newData.exists() || (newData.hasChildren(['room_id','created_at']) && newData.getPriority() == null && newData.child('created_at').isNumber() && newData.child('created_at').val() >= now - 2000 && newData.child('created_at').val() <= now + 2000 && (!data.exists() || newData.child('created_at').val() > data.child('created_at').val()))",
        "room_id": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 128"
        },
        "created_at": {
          ".validate": "newData.isNumber()"
        },
        "$other": {
          ".validate": false
        }
      }
    },
    "rooms": {
      ".read": false,
      ".write": false,
      ".indexOn": ["private/created_at"],
      "$roomId": {
        ".read": false,
        ".write": false,
        "private": {
          ".read": false,
          ".write": false,
          "creator_uid": {
            ".validate": "newData.isString()"
          },
          "responder_uid": {
            ".validate": "newData.isString() || newData.val() == null"
          },
          "created_at": {
            ".validate": "newData.isNumber()"
          },
          "$other": {
            ".validate": false
          }
        },
        "meta": {
          ".read": "auth != null",
          ".write": false,
          "state": {
            ".validate": "newData.isNumber() && (newData.val() == 1 || newData.val() == 2)"
          },
          "deleteRequested": {
            ".validate": "newData.isBoolean() && newData.val() == true",
            ".write": "auth != null && !data.exists() && newData.val() == true && (auth.uid == root.child('rooms').child($roomId).child('private').child('creator_uid').val() || auth.uid == root.child('rooms').child($roomId).child('private').child('responder_uid').val()) && root.child('rooms').child($roomId).child('messages').child('creator').child('pake').child('msg').exists() && root.child('rooms').child($roomId).child('messages').child('creator').child('pake').child('mac_tag').exists() && root.child('rooms').child($roomId).child('messages').child('creator').child('rtc').child('msg').exists() && root.child('rooms').child($roomId).child('messages').child('responder').child('pake').child('msg').exists() && root.child('rooms').child($roomId).child('messages').child('responder').child('pake').child('mac_tag').exists() && root.child('rooms').child($roomId).child('messages').child('responder').child('rtc').child('msg').exists()"
          },
          "$other": {
            ".validate": false
          }
        },
        "messages": {
          ".read": "auth != null && (auth.uid == root.child('rooms').child($roomId).child('private').child('creator_uid').val() || auth.uid == root.child('rooms').child($roomId).child('private').child('responder_uid').val())",
          ".write": false,
          "creator": {
            ".read": "auth != null && (auth.uid == root.child('rooms').child($roomId).child('private').child('creator_uid').val() || auth.uid == root.child('rooms').child($roomId).child('private').child('responder_uid').val())",
            ".write": false,
            "pake": {
              ".read": "auth != null && (auth.uid == root.child('rooms').child($roomId).child('private').child('creator_uid').val() || auth.uid == root.child('rooms').child($roomId).child('private').child('responder_uid').val())",
              ".write": false,
              "msg": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 64",
                ".write": "auth != null && auth.uid == root.child('rooms').child($roomId).child('private').child('creator_uid').val() && !data.exists() && newData.exists() && root.child('rooms').child($roomId).child('meta').child('state').exists() && root.child('rooms').child($roomId).child('meta').child('state').val() >= 1"
              },
              "mac_tag": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 64",
                ".write": "auth != null && auth.uid == root.child('rooms').child($roomId).child('private').child('creator_uid').val() && !data.exists() && newData.exists() && root.child('rooms').child($roomId).child('messages').child('creator').child('pake').child('msg').exists() && root.child('rooms').child($roomId).child('meta').child('state').exists() && root.child('rooms').child($roomId).child('meta').child('state').val() >= 1"
              },
              "$other": {
                ".validate": false
              }
            },
            "rtc": {
              ".read": "auth != null && (auth.uid == root.child('rooms').child($roomId).child('private').child('creator_uid').val() || auth.uid == root.child('rooms').child($roomId).child('private').child('responder_uid').val())",
              ".write": false,
              "msg": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 32768",
                ".write": "auth != null && auth.uid == root.child('rooms').child($roomId).child('private').child('creator_uid').val() && !data.exists() && newData.exists() && root.child('rooms').child($roomId).child('messages').child('creator').child('pake').child('mac_tag').exists() && root.child('rooms').child($roomId).child('meta').child('state').exists() && root.child('rooms').child($roomId).child('meta').child('state').val() >= 1"
              },
              "$other": {
                ".validate": false
              }
            },
            "$other": {
              ".validate": false
            }
          },
          "responder": {
            ".read": "auth != null && (auth.uid == root.child('rooms').child($roomId).child('private').child('creator_uid').val() || auth.uid == root.child('rooms').child($roomId).child('private').child('responder_uid').val())",
            ".write": false,
            "pake": {
              ".read": "auth != null && (auth.uid == root.child('rooms').child($roomId).child('private').child('creator_uid').val() || auth.uid == root.child('rooms').child($roomId).child('private').child('responder_uid').val())",
              ".write": false,
              "msg": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 64",
                ".write": "auth != null && auth.uid == root.child('rooms').child($roomId).child('private').child('responder_uid').val() && !data.exists() && newData.exists() && root.child('rooms').child($roomId).child('meta').child('state').exists() && root.child('rooms').child($roomId).child('meta').child('state').val() >= 2"
              },
              "mac_tag": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 64",
                ".write": "auth != null && auth.uid == root.child('rooms').child($roomId).child('private').child('responder_uid').val() && !data.exists() && newData.exists() && root.child('rooms').child($roomId).child('messages').child('responder').child('pake').child('msg').exists() && root.child('rooms').child($roomId).child('meta').child('state').exists() && root.child('rooms').child($roomId).child('meta').child('state').val() >= 2"
              },
              "$other": {
                ".validate": false
              }
            },
            "rtc": {
              ".read": "auth != null && (auth.uid == root.child('rooms').child($roomId).child('private').child('creator_uid').val() || auth.uid == root.child('rooms').child($roomId).child('private').child('responder_uid').val())",
              ".write": false,
              "msg": {
                ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 32768",
                ".write": "auth != null && auth.uid == root.child('rooms').child($roomId).child('private').child('responder_uid').val() && !data.exists() && newData.exists() && root.child('rooms').child($roomId).child('messages').child('responder').child('pake').child('mac_tag').exists() && root.child('rooms').child($roomId).child('meta').child('state').exists() && root.child('rooms').child($roomId).child('meta').child('state').val() >= 2"
              },
              "$other": {
                ".validate": false
              }
            },
            "$other": {
              ".validate": false
            }
          },
          "$other": {
            ".validate": false
          }
        },
        "$other": {
          ".validate": false
        }
      }
    }
  }
}
