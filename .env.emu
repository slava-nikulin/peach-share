VITE_USE_EMULATORS=true
VITE_USE_LOCAL_SECURED_CONTEXT=false
VITE_FIREBASE_FORCE_WEBSOCKETS=true

# Firebase project
VITE_FIREBASE_PROJECT_ID=demo-peach-share
VITE_FIREBASE_API_KEY=dev-key
VITE_FIREBASE_APP_ID=demo-app

VITE_EMULATOR_HOST=127.0.0.1

# RTDB Emulator
VITE_EMULATOR_RTDB_PORT=9000
VITE_EMULATOR_RTD_NS=demo-peach-share

# Auth Emulator
VITE_EMULATOR_AUTH_PORT=9099
